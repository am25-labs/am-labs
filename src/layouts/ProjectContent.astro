---
import GridContainer from "@/layouts/GridContainer.astro";
import GridTwo from "@/layouts/grids/GridTwo.astro";
import GridFour from "@/layouts/grids/GridFour.astro";
import { ProseRenderer } from "@/components/ProseRenderer";
import { Table, TableBody, TableRow, TableCell } from "@/components/ui/table";
import Card from "@/components/ui/astro/Card.astro";
import type { ProjectContentProps } from "@/types";
import ProjectCtaDialog from "@/components/project/ProjectCtaDialog";
import {
  PackageIcon,
  ServerIcon,
  CalendarIcon,
  RefreshCwIcon,
  TagIcon,
  BookOpenIcon,
} from "@lucide/astro";

type Props = ProjectContentProps;

const { title, icon, description, details, meta, get_started } = Astro.props;

const metaIconMap: Record<string, any> = {
  Repository: PackageIcon,
  Deployment: ServerIcon,
  Started: CalendarIcon,
  Updated: RefreshCwIcon,
  Version: TagIcon,
  Documentation: BookOpenIcon,
};
---

<GridContainer class="mb-16">
  <GridTwo />

  <GridFour>
    <div class="col-span-full">
      <div class="flex flex-row items-center gap-4 mb-8">
        <div class="border p-2 aspect-square">
          <img
            src={icon}
            alt={title}
            class="w-6 group-data-[variant=yellow]:brightness-0 group-data-[variant=light]:brightness-0"
          />
        </div>

        <h1 class="text-2xl font-bold">{title}</h1>
      </div>

      <div class="space-y-8">
        <ProseRenderer content={description} />

        <Table>
          <TableBody>
            {
              details.map((detail) => (
                <TableRow className="group-data-[variant=yellow]:hover:bg-muted/10 group-data-[variant=light]:hover:bg-muted/10">
                  <TableCell className="font-bold w-1/3 align-top">
                    {detail.label}
                  </TableCell>
                  <TableCell>
                    <div class="[&_p]:pb-0 [&_p]:leading-none">
                      <ProseRenderer content={detail.content} />
                    </div>
                  </TableCell>
                </TableRow>
              ))
            }
          </TableBody>
        </Table>
      </div>
    </div>
  </GridFour>

  <GridTwo>
    <div class="col-span-full">
      {get_started && <ProjectCtaDialog {get_started} client:load />}

      <Card
        class="group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black"
      >
        <div slot="content">
          <ul class="space-y-4">
            {
              meta.map((item) => {
                const Icon = metaIconMap[item.label];
                return (
                  <li class="flex items-center gap-2" title={item.label}>
                    {Icon && (
                      <Icon
                        size={16}
                        class="text-muted-foreground group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black shrink-0"
                      />
                    )}
                    <div class="[&_p]:pb-0 [&_p]:leading-none">
                      <ProseRenderer content={item.content} />
                    </div>
                  </li>
                );
              })
            }
          </ul>
        </div>
      </Card>
    </div>
  </GridTwo>
</GridContainer>
