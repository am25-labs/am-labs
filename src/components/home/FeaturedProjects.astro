---
import GridContainer from "@/layouts/GridContainer.astro";
import GridTwo from "@/layouts/grids/GridTwo.astro";
import GridSix from "@/layouts/grids/GridSix.astro";
import LogoTile from "@/components/LogoTile.astro";
import type { LogoTileProps } from "@/types";

const repos: LogoTileProps[] = [
  {
    logo: "/okra-icon.svg",
    title: "OKRA",
    href: "/project/okra",
  },
  {
    logo: "/webpush-icon.svg",
    title: "Web Push Server",
    href: "/project/webpush",
  },
  {
    logo: "/gate-icon.svg",
    title: "Gate IdP",
    href: "/project/gate-idp",
  },
];
---

<GridContainer class="pb-24">
  <GridTwo>
    <div class="col-span-full">
      <h2
        class="text-muted-foreground group-data-[variant=yellow]:text-black text-sm font-bold uppercase"
      >
        Featured projects
      </h2>
    </div>
  </GridTwo>

  <GridSix gap="gap-4">
    {
      repos.map((repo) => (
        <div class="col-span-1">
          <LogoTile {...repo} />
        </div>
      ))
    }
  </GridSix>
</GridContainer>
