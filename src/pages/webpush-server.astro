---
import { getEntry, render } from "astro:content";
import RootLayout from "@/layouts/RootLayout.astro";
import PageDescription from "@/components/PageDescription.astro";
import ProjectContent from "@/layouts/ProjectContent.astro";

const entry = await getEntry("projects", "webpush");
if (!entry) return new Response(null, { status: 404 });
await render(entry);
const {
  title,
  icon,
  description,
  details,
  license,
  repository,
  availability,
  deployment,
  started,
  updated,
  owner,
} = entry.data;
---

<RootLayout title={`${title} | AM25 Labs`}>
  <PageDescription {description} />

  <ProjectContent
    {title}
    {icon}
    description={entry.body ?? ""}
    {details}
    {license}
    {repository}
    {availability}
    {deployment}
    {started}
    {updated}
    {owner}
  />
</RootLayout>
